# PostgreSQL direct connection (source of truth for chat messages)
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Optional: Redis for chat WS fan-out across multiple API instances (Pub/Sub only).
# Leave empty for single-process dev; set in production when scaling horizontally.
# REDIS_URL=redis://localhost:6379/0

# Firebase Admin SDK
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# External APIs
POLYGON_API_KEY=xxx
ALPACA_API_KEY=xxx
ALPACA_API_SECRET=xxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# File storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# LiveKit RTC
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Server
PORT=3000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Feature flags ──
# Copy-trading profit share (HWM, snapshot-locked rate).
# When OFF (default):
#   — All profit-share logic is bypassed: SettleToBucketWithCommission
#     still runs the HWM math but share_amount is forced to 0 and no
#     wallet transfer or audit-record write happens.
#   — trader dashboard shows zero lifetime/this_month but is still
#     reachable; the default-rate slider is writable. No follower
#     actually gets charged yet.
# Flip to "true" ONLY after:
#   1. Migration 027 has run in prod.
#   2. Existing traders have been notified their default_profit_share_rate
#      is 0 (backfilled) and they need to opt in.
#   3. Monitoring is in place for the metrics listed in the profit-share
#      PRD (section 7.3): transaction success rate, daily audit-vs-wallet
#      reconciliation, single-share-amount upper bound.
# Rollback: flip back to "false" and redeploy — no data migration needed.
PROFIT_SHARE_ENABLED=false
