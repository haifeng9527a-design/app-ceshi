# PostgreSQL direct connection (source of truth for chat messages)
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# Optional: Redis for chat WS fan-out across multiple API instances (Pub/Sub only).
# Leave empty for single-process dev; set in production when scaling horizontally.
# REDIS_URL=redis://localhost:6379/0

# Firebase Admin SDK
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# External APIs
POLYGON_API_KEY=xxx
ALPACA_API_KEY=xxx
ALPACA_API_SECRET=xxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# File storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# LiveKit RTC
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Udun enterprise wallet
# Keep disabled until the full merchant test credentials are confirmed.
UDUN_ENABLED=false
# Example dedicated merchant node shown by Udun is often like:
#   https://sig11.udun.io
UDUN_GATEWAY_BASE_URL=https://sig11.udun.io
UDUN_API_KEY=replace-with-your-udun-api-key
UDUN_MERCHANT_ID=replace-with-your-merchant-id
UDUN_SIGN_SECRET=replace-with-your-sign-secret
# Public callback URLs that Udun can reach from its servers.
UDUN_CALLBACK_DEPOSIT_URL=https://your-domain.com/api/integrations/udun/callback/deposit
UDUN_CALLBACK_WITHDRAW_URL=https://your-domain.com/api/integrations/udun/callback/withdraw
UDUN_REQUEST_TIMEOUT_MS=15000
UDUN_RETRY_MAX_ATTEMPTS=3

# Server
PORT=3000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Feature flags ──
# Copy-trading profit share (HWM, snapshot-locked rate).
# When OFF (default):
#   — All profit-share logic is bypassed: SettleToBucketWithCommission
#     still runs the HWM math but share_amount is forced to 0 and no
#     wallet transfer or audit-record write happens.
#   — trader dashboard shows zero lifetime/this_month but is still
#     reachable; the default-rate slider is writable. No follower
#     actually gets charged yet.
# Flip to "true" ONLY after:
#   1. Migration 027 has run in prod.
#   2. Existing traders have been notified their default_profit_share_rate
#      is 0 (backfilled) and they need to opt in.
#   3. Monitoring is in place for the metrics listed in the profit-share
#      PRD (section 7.3): transaction success rate, daily audit-vs-wallet
#      reconciliation, single-share-amount upper bound.
# Rollback: flip back to "false" and redeploy — no data migration needed.
PROFIT_SHARE_ENABLED=false

# Referral + agent program (PRD: docs/referral_agent_program_prd.md).
# When OFF (default):
#   — RecordCommissionEvent 第一行 return，零 DB 写入；
#   — daily scheduler 不注册 cron；
#   — Register 即使带 invite_code 也跳过 BindReferrer；
#   — 交易链路无任何延迟（埋点直接短路）
# Flip to "true" ONLY after:
#   1. Migration 031 has run in prod.
#   2. Backfill 核对：每个 users 有 1 条默认 invite_link 且 my_rebate_rate 全 0.10
#   3. 监控到位：referral_daily_settle_total / referral_cascade_depth_histogram /
#                 wallet_transactions type ∈ (referral_commission_in, agent_override_in) 一致性
# Rollback: flip back to "false" + redeploy；代码 revert 只需 commit 6 的埋点拆除。
REFERRAL_ENABLED=false

# Rate 上限（Flag on 后生效）
# PLATFORM_USER_DEFAULT_RATE：新注册用户默认 my_rebate_rate（0.10 = 10%）
# PLATFORM_USER_MAX_RATE    ：普通用户（is_agent=false）rate 硬上限
# PLATFORM_AGENT_MAX_RATE   ：代理 rate 硬上限（admin 给出）
# DAILY_COMMISSION_CAP_USD  ：单个 inviter 单日入账上限（USD）；0 或负数 = 无上限
PLATFORM_USER_DEFAULT_RATE=0.10
PLATFORM_USER_MAX_RATE=0.20
PLATFORM_AGENT_MAX_RATE=1.00
DAILY_COMMISSION_CAP_USD=10000
